lwd = 2, bty = "n")
X = data$mage
h_ll = KernSmooth::dpill(X, Y)
cat("Bandwidth: h =", round(h_ll, 3), "\n")
fit_ll = KernSmooth::locpoly(X, Y, bandwidth = h_ll, degree = 1,
gridsize = 401)
plot(fit_ll, type = "l", lwd = 2, col = "black",
xlab = "Mother's Age", ylab = "Birth Weight",
main = expression("Local Linear Estimate of " * E*"["*Y*"|"*X*"]"))
rug(X, col = rgb(0, 0, 0, 0.05))
cv_poly = function(J, X, Y) {
P = poly(X, degree = J, raw = TRUE)
fit = lm(Y ~ P)
h_ii = hatvalues(fit)
mean(((Y - fitted(fit)) / (1 - h_ii))^2)
}
J_grid = 1:10
cv_vals = sapply(J_grid, function(j) cv_poly(j, X, Y))
J_opt = J_grid[which.min(cv_vals)]
cat("Polynomial degree: J =", J_opt, "\n")
plot(J_grid, cv_vals, type = "b", pch = 19,
xlab = "Polynomial Degree J", ylab = "LOOCV Score",
main = "Cross-Validation for Series Terms")
abline(v = J_opt, lty = 2, col = "red")
fit_series = lm(Y ~ poly(X, J_opt, raw = TRUE))
x_seq = seq(min(X), max(X), length.out = 300)
pred_series = predict(fit_series, newdata = data.frame(X = x_seq))
plot(x_seq, pred_series, type = "l", lwd = 2, col = "darkgreen",
xlab = "Mother's Age", ylab = "Birth Weight",
main = paste0("Series Estimate (degree ", J_opt, ")"))
rug(X, col = rgb(0, 0, 0, 0.05))
plot(fit_ll, type = "l", lwd = 2, col = "black",
xlab = "Mother's Age (years)", ylab = "Birth Weight (grams)",
main = "Linear vs Series Estimation",
ylim = range(c(fit_ll$y, pred_series)))
lines(x_seq, pred_series, col = "darkgreen", lwd = 2, lty = 2)
legend("bottomright",
legend = c("Local Linear", paste0("Series (J=", J_opt, ")")),
col = c("black", "darkgreen"), lty = c(1, 2), lwd = 2, bty = "n")
rug(X, col = rgb(0, 0, 0, 0.05))
fit_linear = lm(Y ~ X)
summary(fit_linear)
plot(fit_ll, type = "l", lwd = 2, col = "black",
