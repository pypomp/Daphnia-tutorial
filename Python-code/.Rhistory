main = "Nonparametric vs Parametric estimates", ylim = c(0, max(est_kde$y) * 1.1))
lines(x_grid, dnorm(x_grid, mu_hat, sigma_hat),
col = "red", lwd = 2, lty = 2)
lines(x_grid[x_grid > 0],
