data
Y = data$bweight
n = length(Y)
h_sj = KernSmooth::dpik(Y)
cat("Bandwidth: h_SJ =", round(h_sj, 2), "\n")
est_kde = KernSmooth::bkde(Y, bandwidth = h_sj)
plot(est_kde, type = "l", lwd = 2, col = "black",
xlab = "bweight", ylab = "Density",
main = "Kernel Density Estimation")
rug(Y, col = rgb(0, 0, 0, 0.05))
mu_hat = mean(Y)
sigma_hat = sd(Y)
x_grid = seq(min(Y) - 500, max(Y) + 500, length.out = 500)
plot(est_kde, type = "l", lwd = 2, col = "black",
xlab = "bweight", ylab = "Density",
main = "Nonparametric and parametric estimates")
lines(x_grid, dnorm(x_grid, mu_hat, sigma_hat),
col = "red", lwd = 2, lty = 2)
legend("topright",
legend = c("Nonparametric", "Parametric"),
col = c("black", "red"), lty = c(1, 2), lwd = 2, bty = "n")
skew = mean(((Y - mu_hat)/sigma_hat)^3)
cat("Skewness:", round(skew, 3), "\n")
sw = shapiro.test(Y)
cat("Shapiro-Wilk p-value:", format.pval(sw$p.value, digits = 3), "\n")
logY = log(Y)
mu_ln = mean(logY)
sigma_ln = sd(logY)
plot(est_kde, type = "l", lwd = 2, col = "black",
xlab = "bweight", ylab = "Density",
main = "Nonparametric and parametric estimates")
lines(x_grid[x_grid > 0],
dlnorm(x_grid[x_grid > 0], mu_ln, sigma_ln),
col = "blue", lwd = 2, lty = 2)
legend("topright",
legend = c("Nonparametric", "Parametric"),
