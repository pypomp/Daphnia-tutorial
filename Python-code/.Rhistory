library(maxLik)
loglik = function(theta) {
beta0 = c(0, theta[1:4])
beta_price = theta[5]
beta_feature = theta[6]
beta_display = theta[7]
V = matrix(0, nrow(data), num_brand)
for (j in 1:num_brand) {
V[, j] = beta0[j] + beta_price * price[, j] + beta_feature * feature[, j] + beta_display * display[, j]
}
logprob = V - log(rowSums(exp(V)))
ll = sum(Y * logprob)
return(ll)
}
theta0 = rep(0, 7)
result = maxLik(loglik, start = theta0, method = "BFGS")
summary(result)
loglik = function(theta) {
beta0 = c(0, theta[1:4])
beta_price = theta[5]
beta_feature = theta[6]
beta_display = theta[7]
V = matrix(0, nrow(data), num_brand)
for (j in 1:num_brand) {
V[, j] = beta0[j] + beta_price * price[, j] + beta_feature * feature[, j] + beta_display * display[, j]
}
logprob = V - log(rowSums(exp(V)))
ll = sum(Y * logprob)
return(ll)
}
grad = function(theta) {
beta0 = c(0, theta[1:4])
beta_price = theta[5]
beta_feature = theta[6]
beta_display = theta[7]
V = matrix(0, nrow(data), num_brand)
for (j in 1:num_brand) {
V[, j] = beta0[j] + beta_price * price[, j] + beta_feature * feature[, j] + beta_display * display[, j]
}
P = exp(V) / rowSums(exp(V))
diff = Y - P
g = numeric(7)
for (j in 2:num_brand) {
g[j-1] = sum(diff[, j])
}
g[5] = sum(diff * price)
g[6] = sum(diff * feature)
g[7] = sum(diff * display)
return(g)
}
theta0 = rep(0, 7)
result = maxLik(loglik, grad = grad, start = theta0, method = "BFGS")
summary(result)
