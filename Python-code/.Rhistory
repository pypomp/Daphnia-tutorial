num_brand = 5
Y = matrix(0, nrow(data), num_brand)
for (i in 1:nrow(data)) Y[i, data$brand[i]] = 1
price = as.matrix(data[, c("p1","p2","p3","p4","p5")])
feature  = as.matrix(data[, c("f1","f2","f3","f4","f5")])
display  = as.matrix(data[, c("d1","d2","d3","d4","d5")])
neg_loglik = function(theta) {
beta0 = c(0, theta[1:4])
bp = theta[5]
bf = theta[6]
bd = theta[7]
V = matrix(0, nrow(data), num_brand)
for (j in 1:num_brand) {
V[, j] = beta0[j] + bp * price[, j] + bf * feature[, j] + bd * display[, j]
}
expV = exp(V)
denom = rowSums(expV)
logprob = V - log(denom)
ll = sum(Y * logprob)
return(-ll)
}
theta0 = rep(0, 7)
result = optim(theta0, neg_loglik, method = "BFGS", hessian = TRUE)
beta_hat = result$par
se = sqrt(diag(solve(result$hessian)))
names = c("ASC2","ASC3","ASC4","ASC5","Price","feature","displaylay")
estimates = data.frame(
Variable = names,
Estimate = round(beta_hat, 4),
Std.Err = round(se, 4)
)
print(estimates, row.names = FALSE)
