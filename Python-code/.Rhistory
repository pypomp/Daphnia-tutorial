fit_linear = lm(Y ~ X)
summary(fit_linear)
plot(fit_ll, type = "l", lwd = 2, col = "black",
xlab = "Mother's Age (years)", ylab = "Birth Weight (grams)",
main = expression("Nonparametric vs Linear: "*E*"["*Y*"|"*X*"]"))
abline(fit_linear, col = "red", lwd = 2, lty = 2)
legend("bottomright",
legend = c("Local Linear (nonparametric)", "OLS Linear"),
col = c("black", "red"), lty = c(1, 2), lwd = 2, bty = "n")
rug(X, col = rgb(0, 0, 0, 0.05))
fit_quad = lm(Y ~ X + I(X^2))
summary(fit_quad)
peak_age = -coef(fit_quad)["X"] / (2 * coef(fit_quad)["I(X^2)"])
peak_age
x_seq2 = seq(min(X), max(X), length.out = 300)
pred_quad = predict(fit_quad, newdata = data.frame(X = x_seq2))
plot(fit_ll, type = "l", lwd = 2, col = "black",
xlab = "Mother's Age (years)", ylab = "Birth Weight (grams)",
main = expression("Nonparametric vs Quadratic: "*E*"["*Y*"|"*X*"]"))
lines(x_seq2, pred_quad, col = "purple", lwd = 2, lty = 2)
legend("bottomright",
legend = c("Local Linear (nonparametric)", "OLS Quadratic"),
col = c("black", "purple"), lty = c(1, 2), lwd = 2, bty = "n")
rug(X, col = rgb(0, 0, 0, 0.05))
